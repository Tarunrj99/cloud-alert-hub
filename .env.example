# =============================================================================
# Environment variables — secrets and deployment-specific overrides only.
# Copy to .env (or export in your CI / shell) before running locally.
# =============================================================================

# ---- Slack ------------------------------------------------------------------
# Incoming webhook URL. The variable name must match
# notifications.slack.webhook_url_env in your config.yaml (default:
# SLACK_WEBHOOK_URL).
SLACK_WEBHOOK_URL=

# ---- Email (SMTP example) ---------------------------------------------------
# Only required if notifications.email.provider = "smtp" in config.yaml.
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# ---- Runtime overrides (optional) ------------------------------------------
# Any of these override the matching key in config.yaml without editing YAML:
# APP_ENV=nonprod
# APP_CLOUD=gcp
# ALERTING_ENABLED=true
# DRY_RUN=false
# DEBUG_MODE=false
# DEFAULT_ROUTE=finops
# STATE_BACKEND=memory
# STATE_FILE_PATH=/tmp/cloud-alert-hub-dedupe.json

# ---- Local dev server only --------------------------------------------------
# If you run examples/local-dev and set ingress_auth.enabled=true in config.
# INGEST_SHARED_TOKEN=
